# Server
NODE_ENV=development
PORT=3000

# HTTPS (optional) — when enabled the server listens on BOTH http (PORT) and
# https (HTTPS_PORT) at the same time. Point KEY/CERT at PEM files.
# Generate a self-signed dev cert (needs openssl) into ./certs:
#   mkdir certs
#   openssl req -x509 -newkey rsa:2048 -nodes -keyout certs/key.pem \
#     -out certs/cert.pem -days 365 -subj "/CN=localhost"
# HTTPS_ENABLED=true
# HTTPS_PORT=3443
# HTTPS_KEY_PATH=./certs/key.pem
# HTTPS_CERT_PATH=./certs/cert.pem
# Bounce plain http → https (only meaningful when HTTPS_ENABLED=true):
# HTTPS_REDIRECT=false

# Refresh-cookie Secure flag: auto (default) = Secure over https only, so the
# same login flow works over http and https. Force with true/false.
# COOKIE_SECURE=auto
# Set when running behind a reverse proxy so req.secure / X-Forwarded-Proto are
# trusted (true, a hop count, or a subnet). Leave unset when not proxied.
# TRUST_PROXY=true

# Database
# DB_DIALECT can be: sqlite | postgres | mysql | mariadb | mssql
# When omitted, defaults to sqlite using the DB_STORAGE path.
DB_DIALECT=sqlite

# sqlite-only
DB_STORAGE=./data/database.sqlite

# postgres / mysql / mariadb / mssql
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=saas
# DB_USER=postgres
# DB_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# Client URL (for CORS)
CLIENT_URL=http://localhost:5173

# Product display name (used in email subjects and the mailer footer)
APP_NAME=SaaS

# Cache namespace. Existing deployments can retain starter:; use saas: for a
# new branded deployment that shares Redis with other applications.
# REDIS_KEY_PREFIX=saas:


# Billing / subscriptions
# Provider: "manual" (default — assign plans with no gateway) or "stripe".
BILLING_PROVIDER=manual
# Plan slug new organizations are placed on automatically.
BILLING_DEFAULT_PLAN=free
BILLING_CURRENCY=USD
# Stripe is a scaffold — inert until both keys are set and BILLING_PROVIDER=stripe.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

# AI assistant
# Context window Ollama loads the model with. The agent sends all tool schemas
# on every call, so a small context (Ollama's 2048/4096 default) overflows with
# "n_keep >= n_ctx". Raise this if you add many more tools or hit that error.
# AI_NUM_CTX=8192

# LINE integration. Generate a 32-byte key with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
# Do not reuse JWT secrets or commit a real key.
# LINE_CREDENTIAL_ENCRYPTION_KEY=
