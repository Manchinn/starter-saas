# Production Environment Configuration
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git!

# ============================================
# Server Configuration
# ============================================
NODE_ENV=production
PORT=3000

# ============================================
# Database Configuration
# ============================================
# Supported: sqlite | postgres | mysql | mariadb | mssql
DB_DIALECT=postgres
DB_HOST=postgres
DB_PORT=5432
DB_NAME=starter_saas
DB_USER=postgres
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# SQLite only (if using sqlite)
# DB_STORAGE=./data/database.sqlite

# ============================================
# JWT Configuration
# ============================================
# Generate strong secrets: openssl rand -base64 48
JWT_SECRET=CHANGE_THIS_TO_RANDOM_64_CHAR_STRING
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_RANDOM_64_CHAR_STRING
JWT_REFRESH_EXPIRES_IN=7d

# LINE credential encryption. Generate with:
# node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
LINE_CREDENTIAL_ENCRYPTION_KEY=CHANGE_THIS_TO_A_BASE64_32_BYTE_KEY

# ============================================
# Redis Configuration (Optional but recommended)
# ============================================
REDIS_ENABLED=true
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_THIS_REDIS_PASSWORD
REDIS_DB=0
REDIS_KEY_PREFIX=starter:
REDIS_TTL=3600

# ============================================
# Client Configuration
# ============================================
CLIENT_URL=https://yourdomain.com

# ============================================
# SMTP Configuration (Email)
# ============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@yourdomain.com

# ============================================
# Authentication Configuration
# ============================================
REQUIRE_EMAIL_VERIFICATION=false
PASSWORD_RESET_EXPIRES_MINUTES=60
EMAIL_VERIFICATION_EXPIRES_HOURS=24

# ============================================
# Application Configuration
# ============================================
APP_NAME=Starter SaaS

# ============================================
# Docker Compose Ports (Optional)
# ============================================
API_PORT=3000
CLIENT_PORT=8080
DB_PORT=5432
REDIS_PORT=6379
